{
  "entryPoints": ["src", "electron", "shared", "database", "wsserver"],
  "entryPointStrategy": "expand",
  "out": "docs/projectDocsGen",
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "coverage/**",
    "docs/**",
    "dist/**",
    "dist-electron/**",
